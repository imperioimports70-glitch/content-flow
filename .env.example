# Copie para .env.local e preencha com o projeto Supabase (Settings > API).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Opcional — só para Supabase CLI (pnpm supabase:db:push / functions:deploy).
# Gere em: https://supabase.com/dashboard/account/tokens
# Nunca exponha no frontend; não use prefixo VITE_.
# SUPABASE_ACCESS_TOKEN=
